{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "config": {
      "buildCommand": "pnpm install && pnpm --filter @zeus/web build"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm --filter @zeus/web start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "environmentVariables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
