{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "config": {
      "buildCommand": "cd apps/api && pnpm install && pnpm run build"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd apps/api && pnpm run start:prod",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthcheck": {
      "type": "http",
      "path": "/health",
      "interval": 10,
      "timeout": 5,
      "successThreshold": 1,
      "failureThreshold": 3
    }
  },
  "environmentVariables": {
    "NODE_ENV": "production",
    "PORT": "3001",
    "LOG_LEVEL": "info"
  },
  "volumes": [
    {
      "name": "logs",
      "mountPath": "/app/logs"
    }
  ]
}
