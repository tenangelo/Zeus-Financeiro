# =============================================================================
# ZEUS FINANCEIRO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — obter em: https://supabase.com/dashboard/project/<id>/settings/api
# -----------------------------------------------------------------------------

# URL pública do projeto Supabase (segura para expor no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co

# Chave anônima — submetida a RLS, segura para o frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave de serviço — bypassa RLS, usar APENAS no backend (NestJS)
# NUNCA expor no frontend ou versionar no git
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL interna do Supabase (para o backend no mesmo ambiente)
SUPABASE_URL=https://<project-id>.supabase.co

# JWT Secret — obter em: Project Settings > API > JWT Settings
# Usado pelo NestJS para validar tokens do Supabase Auth
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------

# URL do frontend (usado pelo NestJS para configurar CORS)
FRONTEND_URL=http://localhost:3000

# Porta da API NestJS
PORT=3001

# Ambiente: development | staging | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# IA — obter em: https://platform.openai.com/api-keys
# Usado pelo AI Worker para gerar insights e embeddings
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# WHATSAPP (escolher um dos dois)
# -----------------------------------------------------------------------------

# Opção A: Evolution API (self-hosted, gratuito)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=zeus-financeiro

# Opção B: Twilio (cloud, pago por mensagem)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------------------------------------------------------
# REDIS — usado pelo BullMQ para filas de processamento de CMV e importações
# Localmente: docker run -d -p 6379:6379 redis:7-alpine
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# SUPABASE CLI (desenvolvimento local)
# Geradas automaticamente pelo `supabase start`
# -----------------------------------------------------------------------------
# SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
